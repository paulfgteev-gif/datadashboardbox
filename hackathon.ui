     <property name="styleSheet">
      <string notr="true">/* 1. Default 'OFF' State */
QPushButton {
    background-color: #e74c3c; /* Red */
    color: white;
    border-radius: 30px;
    padding: 5px;
    border: 3px solid black;
}

/* 2. 'OFF' State while Hovering */
QPushButton:hover {
    background-color: #ff5e4d; /* Lighter Red */
}

/* 3. 'ON' State (The Fix) */
/* This covers both normal 'ON' and 'ON' while hovering */
QPushButton:checked, 
QPushButton:checked:hover {
    background-color: #2ecc71; /* Solid Green */
    color: white;
}

/* 4. Optional: A slightly darker green when clicking to turn OFF */
QPushButton:checked:pressed {
    background-color: #27ae60;
}</string>
